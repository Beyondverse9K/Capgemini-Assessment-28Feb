<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE hibernate-configuration PUBLIC
        "-//Hibernate/Hibernate Configuration DTD 3.0//EN"
        "http://hibernate.sourceforge.net/hibernate-configuration-3.0.dtd">

<hibernate-configuration>
    <session-factory>
        <!-- Database connection settings -->
        <property name="hibernate.connection.driver_class">org.postgresql.Driver</property>
        <property name="hibernate.connection.url">jdbc:postgresql://localhost:5432/Hibernate</property>
        <property name="hibernate.connection.username">orclDee</property>
        <property name="hibernate.connection.password">tiger</property>

        <!-- JDBC connection pool (built-in) -->
        <property name="hibernate.connection.pool_size">10</property>

        <!-- SQL dialect for PostgreSQL -->
        <property name="hibernate.dialect">org.hibernate.dialect.PostgreSQLDialect</property>

        <!-- Enable SQL logging -->
        <property name="hibernate.show_sql">true</property>
        <property name="hibernate.format_sql">true</property>

        <!-- Automatically create/update schema -->
        <!-- Options: validate | update | create | create-drop -->
        <property name="hibernate.hbm2ddl.auto">update</property>

        <!-- Entity mapping files or annotated classes -->
        <!-- Example for annotated class -->
        <mapping class="com.example.model.YourEntity"/>

        <!-- Example for XML mapping file -->
        <!-- <mapping resource="com/example/model/YourEntity.hbm.xml"/> -->

    </session-factory>
</hibernate-configuration>
